# Autotask REST API credentials
#
# Step 1: find your zone URL (no auth needed):
#   node scripts/getZone.js your-api-user@example.com
#
# Step 2: fill in the values below and save as .env

AUTOTASK_BASE_URL=https://webservices1.autotask.net/atservicesrest/v1.0

# API user credentials (Admin > Resources/Users > API Users)
AUTOTASK_USERNAME=your-api-user@example.com
AUTOTASK_SECRET=your-api-user-secret

# Integration code for this application (same Admin page as above)
AUTOTASK_INTEGRATION_CODE=your-integration-code
